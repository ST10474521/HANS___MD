# HANS MD ENVIRONMENT VARIABLES - EXAMPLE
# "name": "hans___md",
# Rename this file to .env and fill in your details

# --- Bot Identity & Pairing ---
# OWNER_NUMBER is required for the interactive pairing flow.
BOT_NAME=HANS MD
OWNER_NAME=Harold
OWNER_NUMBER=237680260772
PREFIX=.

# --- Automation Settings (true/false) ---
AUTO_REACT=true
ANTI_DELETE=true
AUTO_READ=true
AUTO_STATUS=true
AUTO_TYPING=true
AUTO_RECORDING=true
ALWAYS_ONLINE=true

# --- External Integration ---
GITHUB_URL=https://github.com/haroldmth/hans___md
REPO_NAME=hans___md

# --- Notifications & Reporting ---
# Telegram Bot Token for error reporting (Optional)
TG_BOT_TOKEN=
TG_CHAT_ID=
